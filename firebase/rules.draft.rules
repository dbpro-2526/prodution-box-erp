// firebase/rules.draft.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /Demands/{demandId} {
      allow create: if request.auth != null && (request.resource.data.createdBy.uid == request.auth.uid);

      // Read: allow if requester, or user in same assigned scope, or admin
      allow read: if isRequesterOrAssignedOrAdmin(resource);

      // Update: allow only through cloud functions (restrict client updates)
      allow update: if false;
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role in ['SuperAdmin', 'Admin'];
    }

    function isRequesterOrAssignedOrAdmin(resource) {
      if (request.auth == null) return false;
      if (resource.data.createdBy.uid == request.auth.uid) return true;
      if (isAdmin()) return true;
      // Additional logic: check user's assigned scope (region/state/division/warehouse)
      return false; // placeholder — implement detailed checks per your Users/Assignments model
    }
  }
}
